# API Configuration
# Copy this file to .env and update the values as needed

# Spring Boot Backend URL (Main API)
VITE_SPRING_BACKEND_URL=http://localhost:8080

# Node.js Server URL (Email/Query service)
VITE_NODE_SERVER_URL=http://localhost:3001

# Development vs Production
# For production, you might want:
# VITE_SPRING_BACKEND_URL=https://your-production-domain.com
# VITE_NODE_SERVER_URL=https://your-production-domain.com
